# ====================================
# z7Note 环境配置文件示例
# ====================================
# 复制此文件为 .env 并根据实际情况修改配置

# ====================================
# 服务器配置
# ====================================
PORT=3000
HOST=0.0.0.0

# ====================================
# 配额配置（MB）
# ====================================
# 新用户默认笔记空间限制（MB）
DEFAULT_NOTE_LIMIT=10
# 新用户默认附件空间限制（MB）
DEFAULT_FILE_LIMIT=50
# 单个文件最大大小（MB）
MAX_FILE_SIZE=500

# ====================================
# 文件类型配置
# ====================================
# 允许的文件类型（逗号分隔的MIME类型）
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml,application/pdf,text/plain,text/markdown,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/zip,application/x-rar-compressed,application/x-7z-compressed,video/mp4,video/webm,audio/mpeg,audio/wav

# ====================================
# 分片上传配置
# ====================================
# 是否启用分片上传
CHUNK_UPLOAD_ENABLED=true
# 分片大小（MB）
CHUNK_SIZE=5
# 分片上传最大重试次数
CHUNK_MAX_RETRIES=3

# ====================================
# 图片压缩配置
# ====================================
# 是否启用图片压缩
IMAGE_COMPRESSION_ENABLED=true
# 压缩质量（0-100，值越小压缩率越高）
IMAGE_COMPRESSION_QUALITY=85
# 图片最大宽度（像素，0表示不限制）
IMAGE_COMPRESSION_MAX_WIDTH=1920
# 图片最大高度（像素，0表示不限制）
IMAGE_COMPRESSION_MAX_HEIGHT=1080

# ====================================
# 动态限流配置
# ====================================
# 是否启用动态限流
DYNAMIC_RATE_LIMIT_ENABLED=true
# 上传速率限制（次/分钟）
UPLOAD_RATE_LIMIT=20

# ====================================
# 管理员配置
# ====================================
# 管理员用户名（多个用户用逗号分隔）
ADMIN_USER=admin

# ====================================
# 邮箱配置（SMTP）
# ====================================
# 邮件发送服务器
SMTP_HOST=localhost
SMTP_PORT=587
# 是否使用SSL/TLS（true/false）
SMTP_SECURE=false
# 邮箱账号
SMTP_USER=your_email@example.com
# 邮箱密码或授权码（如163邮箱使用授权码）
SMTP_PASS=your_password

